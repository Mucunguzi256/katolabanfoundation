---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/what-we-do', label: 'What We Do' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/news', label: 'News' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="relative bg-white shadow-sm sticky top-0 z-50 overflow-hidden">
  <!-- SVG Pattern Overlay -->
  <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="nav-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="20" cy="20" r="1.5" fill="#1E3A8A"/>
          <path d="M0 20 Q10 15 20 20 T40 20" stroke="#1E3A8A" stroke-width="0.5" fill="none" opacity="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#nav-pattern)"/>
    </svg>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <a href="/" class="flex items-center">
        <img src="/logo.png" alt="Kato Laban Foundation" class="h-10 w-10 object-contain mr-3 bg-white rounded p-0.5" />
        <span class="text-indigo-800 font-bold text-lg">Kato Laban Foundation</span>
      </a>

      <nav class="hidden md:flex items-center space-x-8">
        {navLinks.map(link => (
          <a 
            href={link.href} 
            class:list={[
              'text-sm font-medium transition-colors duration-200',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-indigo-700'
                : 'text-gray-600 hover:text-indigo-600'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:block">
        <a href="/get-involved" class="bg-indigo-700 hover:bg-indigo-800 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors duration-200">Donate</a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600 hover:text-indigo-700">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col space-y-2">
        {navLinks.map(link => (
          <a href={link.href} class="text-gray-600 hover:text-indigo-600 py-2 border-b border-gray-100">{link.label}</a>
        ))}
        <a href="/get-involved" class="bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-semibold text-center mt-2">Donate</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => menu.classList.toggle('hidden'));
  }
</script>