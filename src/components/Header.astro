---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/what-we-do', label: 'What We Do' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/news', label: 'News' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="bg-blue-800 text-white shadow-md sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
    <a href="/" class="flex items-center">
      <img src="/logo.png" alt="Kato Laban Foundation" class="h-10 w-10 object-contain mr-3" />
      <span class="text-xl font-bold hidden sm:block">KATO LABAN FOUNDATION</span>
    </a>

    <nav class="hidden md:flex items-center space-x-6">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          class:list={[
            'text-sm font-medium transition-colors duration-200',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-white'
              : 'text-blue-100 hover:text-white'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a href="/get-involved" class="bg-white text-blue-800 px-4 py-2 rounded-lg font-semibold hover:bg-blue-50 transition-colors duration-200">Donate</a>
  </div>
</header>