---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="wave-divider">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="#1A1A1A"></path>
    </svg>
  </div>
  
  <div class="footer-content">
    <div class="footer-grid">
      <div class="footer-brand">
        <h3>Kato Laban Foundation</h3>
        <p>Empowering communities in Isingiro District by providing knowledge and sustainable development that enhances a quality life for the most vulnerable populations.</p>
      </div>
      <div class="footer-links">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/what-we-do">What We Do</a></li>
          <li><a href="/get-involved">Get Involved</a></li>
          <li><a href="/news">News</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-contact">
        <h4>Contact Us</h4>
        <ul>
          <li>Kikagate Town Council</li>
          <li>Isingiro District</li>
          <li>Uganda</li>
          <li><a href="tel:+256784332800">+256 784 332 800</a></li>
          <li><a href="mailto:contact@katolabanfoundation.org">contact@katolabanfoundation.org</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} Kato Laban Foundation. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #1A1A1A;
    color: #E5E7EB;
    position: relative;
  }

  .wave-divider {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
    transform: rotate(180deg);
  }

  .wave-divider svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 48px;
  }

  .wave-divider path {
    fill: #1A1A1A;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand h3 {
    color: #FFFFFF;
    font-size: 1.25rem;
    margin-bottom: 1rem;
    font-family: 'Playfair Display', serif;
  }

  .footer-brand p {
    color: #9CA3AF;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
  }

  .footer-links h4,
  .footer-contact h4 {
    color: #FFFFFF;
    font-size: 1rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .footer-links ul,
  .footer-contact ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li,
  .footer-contact li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #FFFFFF;
  }

  .footer-contact li {
    color: #9CA3AF;
    font-size: 0.9rem;
  }

  .footer-contact a {
    color: #9CA3AF;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-contact a:hover {
    color: #FFFFFF;
  }

  .footer-bottom {
    border-top: 1px solid #404040;
    padding-top: 1.5rem;
    text-align: center;
  }

  .footer-bottom p {
    color: #6B7280;
    font-size: 0.85rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .wave-divider svg {
      height: 32px;
    }

    .footer-content {
      padding-top: 2rem;
    }
  }
</style>