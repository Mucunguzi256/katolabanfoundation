---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-section">
        <h3>Kato Laban Foundation</h3>
        <p class="tagline">For Health and Education</p>
        <p>Empowering communities in Isingiro District by providing knowledge and sustainable development that enhances a quality life for the most vulnerable populations.</p>
      </div>

      <div class="footer-section">
        <h4>Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/what-we-do">What We Do</a></li>
          <li><a href="/get-involved">Get Involved</a></li>
          <li><a href="/news">News</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>Contact Us</h4>
        <address class="contact-info">
          <p><strong>Kikagate Town Council</strong></p>
          <p>Isingiro District</p>
          <p>Uganda</p>
          <p class="contact-item"><a href="mailto:contact@katolabanfoundation.org">contact@katolabanfoundation.org</a></p>
          <p class="contact-item phone"><a href="tel:+256784332800">+256 784 332 800</a></p>
        </address>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Kato Laban Foundation. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    padding: var(--spacing-3xl) 0 var(--spacing-xl);
    margin-top: var(--spacing-3xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--spacing-2xl);
  }

  .footer-section h3 {
    font-size: var(--font-size-xl);
    color: var(--color-white);
    margin-bottom: var(--spacing-sm);
  }

  .footer-section h4 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-md);
    color: var(--color-white);
  }

  .tagline {
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--spacing-md);
  }

  .footer-section p {
    color: var(--color-neutral-100);
    line-height: 1.7;
  }

  .footer-links li {
    margin-bottom: var(--spacing-sm);
  }

  .footer-links a {
    color: var(--color-neutral-100);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .contact-info {
    font-style: normal;
  }

  .contact-info p {
    margin-bottom: var(--spacing-xs);
    color: var(--color-neutral-100);
  }

  .contact-item {
    margin-top: var(--spacing-sm);
  }

  .contact-info a {
    color: var(--color-white);
    font-weight: 500;
  }

  .contact-info a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid rgba(255,255,255,0.2);
    text-align: center;
  }

  .footer-bottom p {
    color: var(--color-neutral-300);
    font-size: var(--font-size-sm);
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }
  }
</style>