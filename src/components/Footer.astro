---
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-gray-800 text-gray-300">
  <!-- SVG Wave Divider -->
  <div class="absolute top-0 left-0 w-full overflow-hidden leading-0 rotate-180">
    <svg class="relative block w-full h-12" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="#1f2937"></path>
    </svg>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Kato Laban Foundation</h3>
        <p class="text-gray-400 text-sm leading-relaxed">Empowering communities in Isingiro District by providing knowledge and sustainable development that enhances a quality life for the most vulnerable populations.</p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-white transition-colors">About</a></li>
          <li><a href="/what-we-do" class="text-gray-400 hover:text-white transition-colors">What We Do</a></li>
          <li><a href="/get-involved" class="text-gray-400 hover:text-white transition-colors">Get Involved</a></li>
          <li><a href="/news" class="text-gray-400 hover:text-white transition-colors">News</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Contact Us</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>Kikagate Town Council</li>
          <li>Isingiro District</li>
          <li>Uganda</li>
          <li class="pt-2">
            <a href="tel:+256784332800" class="hover:text-white transition-colors">+256 784 332 800</a>
          </li>
          <li>
            <a href="mailto:contact@katolabanfoundation.org" class="hover:text-white transition-colors">contact@katolabanfoundation.org</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-700 pt-8 text-center text-sm text-gray-500">
      <p>&copy; {currentYear} Kato Laban Foundation. All rights reserved.</p>
    </div>
  </div>
</footer>