---
import Layout from '../layouts/Layout.astro';

const programs = [
  {
    label: "Program 01",
    title: "Health & Wellbeing",
    description: "We are dedicated to improving health outcomes for communities in Isingiro District through comprehensive healthcare programs and initiatives.",
    items: [
      "Healthcare Access — Partnering with local health centers",
      "Nutrition Programs — Targeting malnutrition",
      "Health Education — Disease prevention",
      "Mobile Health Clinics — Remote village outreach"
    ]
  },
  {
    label: "Program 02",
    title: "Education Access",
    description: "We believe that education is the foundation for sustainable development. Our education programs focus on expanding access to quality learning opportunities.",
    items: [
      "School Support — Infrastructure and materials",
      "Teacher Training — Professional development",
      "Student Scholarships — Enabling continued education",
      "Literacy Programs — Adult education"
    ]
  },
  {
    label: "Program 03",
    title: "Climate Justice",
    description: "We promote climate education and environmental stewardship while building community resilience to climate change impacts.",
    items: [
      "Climate Awareness — Education programs",
      "Sustainable Agriculture — Climate-smart practices",
      "Reforestation — Community tree planting",
      "Disaster Preparedness — Building capacity"
    ]
  }
];

const impactStats = [
  { number: "3", label: "Schools Supported" },
  { number: "500+", label: "Health Visits" },
  { number: "200+", label: "Trees Planted" }
];
---

<Layout title="What We Do">
  <!-- Hero -->
  <section class="hero-half">
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <nav class="breadcrumb">Home &gt; What We Do</nav>
      <h1>Our Programs</h1>
      <p>Our work addresses health, education, and climate challenges in Isingiro District.</p>
    </div>
  </section>

  <!-- Program 1: Health -->
  <section class="program-section">
    <div class="container">
      <div class="program-grid">
        <div class="program-image">
          <div class="image-placeholder">
            <span>Health Programs</span>
            <div class="corner-accent"></div>
          </div>
        </div>
        <div class="program-content">
          <span class="program-label">Program 01</span>
          <h2>Health & Wellbeing</h2>
          <p>{programs[0].description}</p>
          <ul class="program-items">
            {programs[0].items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Program 2: Education -->
  <section class="program-section dark">
    <div class="container">
      <div class="program-grid reverse">
        <div class="program-image">
          <div class="image-placeholder">
            <span>Education Programs</span>
            <div class="corner-accent"></div>
          </div>
        </div>
        <div class="program-content">
          <span class="program-label">Program 02</span>
          <h2>Education Access</h2>
          <p>{programs[1].description}</p>
          <ul class="program-items">
            {programs[1].items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Program 3: Climate -->
  <section class="program-section">
    <div class="container">
      <div class="program-grid">
        <div class="program-image">
          <div class="image-placeholder">
            <span>Climate Programs</span>
            <div class="corner-accent"></div>
          </div>
        </div>
        <div class="program-content">
          <span class="program-label">Program 03</span>
          <h2>Climate Justice</h2>
          <p>{programs[2].description}</p>
          <ul class="program-items">
            {programs[2].items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Numbers -->
  <section class="impact-stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">3</span>
          <span class="stat-label">Program Areas</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">1000+</span>
          <span class="stat-label">Lives Impacted</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">3</span>
          <span class="stat-label">Schools Supported</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">500+</span>
          <span class="stat-label">Health Visits</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">200+</span>
          <span class="stat-label">Trees Planted</span>
        </div>
      </div>
      <p class="stats-note">// TODO: Replace with real impact data</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-strip">
    <div class="container">
      <p>Want to support these programs? <a href="/get-involved">Get Involved →</a></p>
    </div>
  </section>
</Layout>

<style>
  .hero-half {
    position: relative;
    min-height: 60vh;
    background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(233, 162, 59, 0.15) 0%, transparent 50%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
    padding: 0 2rem;
  }

  .breadcrumb {
    font-size: 0.9rem;
    color: #E9A23B;
    margin-bottom: 1.5rem;
  }

  .hero-half h1 {
    color: #FFFFFF;
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .hero-half p {
    color: #D1D5DB;
    font-size: 1.25rem;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .program-section {
    padding: 6rem 0;
  }

  .program-section.dark {
    background-color: #111827;
  }

  .program-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .program-grid.reverse {
    direction: rtl;
  }

  .program-grid.reverse > * {
    direction: ltr;
  }

  .program-image .image-placeholder {
    position: relative;
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, #2D6A4F 0%, #E9A23B 100%);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .corner-accent {
    position: absolute;
    top: -1rem;
    right: -1rem;
    width: 4rem;
    height: 4rem;
    background-color: #E9A23B;
    border-radius: 1rem;
    opacity: 0.3;
  }

  .program-image span {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.25rem;
    font-weight: 500;
  }

  .program-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #E9A23B;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .program-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .program-section.dark .program-content h2 {
    color: #FFFFFF;
  }

  .program-content p {
    color: #4B5563;
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .program-section.dark .program-content p {
    color: #D1D5DB;
  }

  .program-items {
    list-style: none;
    padding: 0;
  }

  .program-items li {
    color: #4B5563;
    padding: 0.75rem 0;
    border-bottom: 1px solid #E5E7EB;
    padding-left: 1.5rem;
    position: relative;
  }

  .program-items li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #2D6A4F;
    font-weight: 600;
  }

  .program-section.dark .program-items li {
    color: #D1D5DB;
    border-bottom-color: #374151;
  }

  .program-section.dark .program-items li::before {
    color: #E9A23B;
  }

  /* Impact Stats */
  .impact-stats {
    background-color: #2D6A4F;
    padding: 4rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #FFFFFF;
  }

  .stat-label {
    font-size: 0.85rem;
    color: #E9A23B;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  .stats-note {
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    font-style: italic;
    margin-top: 1.5rem;
  }

  /* CTA Strip */
  .cta-strip {
    background: linear-gradient(135deg, #E9A23B 0%, #D4802E 100%);
    padding: 3rem 0;
    text-align: center;
  }

  .cta-strip p {
    font-size: 1.25rem;
    color: #111827;
    font-weight: 500;
  }

  .cta-strip a {
    color: #111827;
    text-decoration: underline;
    font-weight: 700;
  }

  .cta-strip a:hover {
    color: #FFFFFF;
  }

  @media (max-width: 768px) {
    .hero-half { min-height: 50vh; }
    .hero-half h1 { font-size: 2.25rem; }
    .program-grid { grid-template-columns: 1fr; gap: 2rem; }
    .program-grid.reverse { direction: ltr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  }
</style>