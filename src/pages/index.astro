---
import Layout from '../layouts/Layout.astro';

const mission = "To empower communities in Isingiro District by providing knowledge and sustainable development that enhances a quality life for the most vulnerable populations.";

const vision = "To build a thriving, healthy and well educated community where every individual has the opportunity to achieve their full potential.";

const coreValues = "Giving a hand to another, Resilience, Innovation, Prosperity for future generations.";

const workAreas = [
  {
    title: "Health",
    description: "Improving health outcomes for vulnerable populations through healthcare access, nutrition programs, and health education initiatives.",
    icon: "health"
  },
  {
    title: "Education",
    description: "Expanding access to quality education by supporting schools, training teachers, and providing learning materials to students in need.",
    icon: "education"
  },
  {
    title: "Climate Justice",
    description: "Promoting climate education and environmental stewardship while building community resilience to climate change impacts.",
    icon: "climate"
  }
];
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content animate-fade-in-up">
      <h1>Kato Laban Foundation</h1>
      <p class="tagline">For Health and Education</p>
      <p class="hero-text">Empowering communities in Isingiro District to build a healthier, better educated future for all.</p>
      <div class="hero-actions">
        <a href="/get-involved" class="btn btn-accent">Get Involved</a>
        <a href="/what-we-do" class="btn btn-secondary">Learn More</a>
      </div>
    </div>
  </section>

  <section class="section mission-section">
    <div class="container">
      <div class="mission-grid">
        <div class="mission-card animate-fade-in-up" style="animation-delay: 0.1s">
          <h2>Our Mission</h2>
          <p>{mission}</p>
        </div>
        <div class="mission-card animate-fade-in-up" style="animation-delay: 0.2s">
          <h2>Our Vision</h2>
          <p>{vision}</p>
        </div>
        <div class="mission-card values-card animate-fade-in-up" style="animation-delay: 0.3s">
          <h2>Our Core Values</h2>
          <p>{coreValues}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section work-section">
    <div class="container">
      <div class="section-title">
        <h2>What We Do</h2>
        <p>We work across three key areas to create lasting positive change in Isingiro District.</p>
      </div>
      <div class="work-grid">
        {workAreas.map((area, index) => (
          <div class="work-card animate-fade-in-up" style={`animation-delay: ${0.1 + index * 0.1}s`}>
            <div class="work-icon">
              {area.icon === 'health' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>}
              {area.icon === 'education' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>}
              {area.icon === 'climate' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8H5.5a2.5 2.5 0 000 5H8a2 2 0 012 2v1.055M20 21v-8a2 2 0 00-2-2h-1.055M16.5 12.5A2.5 2.5 0 0014 10h-4a2.5 2.5 0 000 5h4a2.5 2.5 0 001.5-2.5z" /></svg>}
            </div>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
            <a href="/what-we-do" class="learn-more">Learn more about {area.title}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Join Us in Making a Difference</h2>
        <p>Your support can help us continue our work in Isingiro District. Whether through donations, volunteering, or spreading the word, every contribution matters.</p>
        <a href="/get-involved" class="btn btn-accent">Get Involved Today</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 550px;
    display: flex;
    align-items: center;
    background-image: url('/foundation.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.55) 0%, rgba(14, 165, 233, 0.5) 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.2;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-4xl) 0;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero h1 {
    color: var(--color-white);
    font-size: var(--font-size-6xl);
    font-weight: 700;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
  }

  .tagline {
    font-size: var(--font-size-xl);
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-text {
    font-size: var(--font-size-lg);
    color: var(--color-neutral-100);
    margin-bottom: var(--spacing-2xl);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero .btn-secondary {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .hero .btn-secondary:hover {
    background-color: var(--color-white);
    color: var(--color-primary);
  }

  .mission-section {
    padding: var(--spacing-4xl) 0;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
  }

  .mission-card {
    background-color: var(--color-white);
    padding: var(--spacing-2xl);
    border-radius: var(--border-radius-xl);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-neutral-100);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .mission-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .mission-card h2 {
    font-size: var(--font-size-2xl);
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
    font-weight: 600;
  }

  .mission-card p {
    color: var(--color-neutral-600);
    line-height: 1.8;
    margin: 0;
  }

  .values-card {
    border-left: 4px solid var(--color-accent);
    background-color: var(--color-neutral-50);
  }

  .values-card:hover {
    border-left-color: var(--color-accent-hover);
  }

  .work-section {
    padding: var(--spacing-4xl) 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-title h2 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
  }

  .section-title p {
    font-size: var(--font-size-lg);
    color: var(--color-neutral-500);
    max-width: 600px;
    margin: 0 auto;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
  }

  .work-card {
    background-color: var(--color-white);
    padding: var(--spacing-2xl);
    border-radius: var(--border-radius-xl);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-neutral-100);
    text-align: center;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .work-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .work-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto var(--spacing-lg);
    background-color: var(--color-primary);
    border-radius: var(--border-radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--transition-base);
  }

  .work-card:hover .work-icon {
    transform: scale(1.1);
  }

  .work-icon svg {
    width: 36px;
    height: 36px;
    color: var(--color-white);
  }

  .work-card h3 {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
  }

  .work-card p {
    color: var(--color-neutral-600);
    margin-bottom: var(--spacing-lg);
    line-height: 1.7;
  }

  .learn-more {
    font-weight: 600;
    color: var(--color-primary);
  }

  .cta-section {
    padding: var(--spacing-3xl) 0;
    text-align: center;
  }

  .cta-content {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--spacing-2xl);
    background-color: var(--color-white);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-neutral-200);
  }

  .cta-section h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .cta-section p {
    color: var(--color-neutral-600);
    margin-bottom: var(--spacing-xl);
    font-size: var(--font-size-lg);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 400px;
    }

    .hero h1 {
      font-size: var(--font-size-3xl);
    }

    .tagline {
      font-size: var(--font-size-lg);
    }

    .mission-grid {
      grid-template-columns: 1fr;
    }

    .work-grid {
      grid-template-columns: 1fr;
    }

    .cta-content {
      padding: 0 var(--spacing-md);
    }
  }
</style>