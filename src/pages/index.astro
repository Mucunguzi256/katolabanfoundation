---
import Layout from '../layouts/Layout.astro';

const mission = "To empower communities in Isingiro District by providing knowledge and sustainable development that enhances a quality life for the most vulnerable populations.";

const vision = "To build a thriving, healthy and well educated community where every individual has the opportunity to achieve their full potential.";

const coreValues = "Giving a hand to another, Resilience, Innovation, Prosperity for future generations.";

const workAreas = [
  {
    title: "Health",
    description: "Improving health outcomes through healthcare access, nutrition programs, and health education initiatives.",
    icon: "health"
  },
  {
    title: "Education",
    description: "Expanding access to quality education by supporting schools, training teachers, and providing learning materials.",
    icon: "education"
  },
  {
    title: "Climate Justice",
    description: "Promoting climate education and environmental stewardship while building community resilience.",
    icon: "climate"
  }
];
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative bg-indigo-900 text-white overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-10">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="header-pattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
            <circle cx="30" cy="30" r="2" fill="white" opacity="0.3"/>
            <circle cx="0" cy="0" r="1.5" fill="white" opacity="0.2"/>
            <circle cx="60" cy="60" r="1.5" fill="white" opacity="0.2"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#header-pattern)"/>
      </svg>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">Kato Laban Foundation</h1>
      <p class="text-lg md:text-xl text-indigo-200 max-w-2xl mx-auto mb-4 uppercase tracking-widest font-semibold">For Health and Education</p>
      <p class="text-lg md:text-xl max-w-2xl mx-auto mb-8 text-indigo-100">Empowering communities in Isingiro District to build a healthier, better-educated future for all.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/get-involved" class="border-2 border-indigo-400 hover:bg-indigo-50 hover:border-indigo-500 text-white hover:text-indigo-700 px-8 py-3 rounded-lg font-semibold transition-all duration-300">Get Involved Today</a>
        <a href="/what-we-do" class="bg-transparent border border-white hover:bg-white hover:text-indigo-900 text-white px-8 py-3 rounded-lg font-semibold transition">Learn More</a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="animated-bg absolute inset-0 z-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-sm font-semibold text-indigo-600 uppercase tracking-widest">About Us</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mt-2 mb-6">Building a Better Future for Isingiro District</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-6">{mission}</p>
          <a href="/about" class="text-indigo-600 font-semibold hover:text-indigo-800 inline-flex items-center">Learn more about us <span class="ml-2">→</span></a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white rounded-xl shadow-sm p-6 text-center border border-gray-100">
            <div class="text-3xl font-bold text-indigo-800">3</div>
            <div class="text-gray-600 text-sm mt-1">Program Areas</div>
          </div>
          <div class="bg-white rounded-xl shadow-sm p-6 text-center border border-gray-100">
            <div class="text-3xl font-bold text-indigo-800">1000+</div>
            <div class="text-gray-600 text-sm mt-1">Lives Impacted</div>
          </div>
          <div class="bg-white rounded-xl shadow-sm p-6 text-center border border-gray-100">
            <div class="text-3xl font-bold text-indigo-800">5+</div>
            <div class="text-gray-600 text-sm mt-1">Years Serving</div>
          </div>
          <div class="bg-white rounded-xl shadow-sm p-6 text-center border border-gray-100">
            <div class="text-3xl font-bold text-indigo-800">1</div>
            <div class="text-gray-600 text-sm mt-1">District Covered</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do Section -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="animated-bg-alt absolute inset-0 z-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-sm font-semibold text-indigo-600 uppercase tracking-widest">What We Do</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mt-2">Our Mission in Action</h2>
        <p class="text-gray-600 text-lg mt-4 max-w-2xl mx-auto">We work across three key areas to create lasting positive change in Isingiro District.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {workAreas.map((area, index) => (
          <div class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-14 h-14 bg-indigo-50 group-hover:bg-indigo-100 rounded-xl flex items-center justify-center mb-6 transition-all duration-300">
              {area.icon === 'health' && (
                <svg class="w-7 h-7 text-indigo-600 group-hover:text-indigo-800 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              )}
              {area.icon === 'education' && (
                <svg class="w-7 h-7 text-indigo-600 group-hover:text-indigo-800 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
              )}
              {area.icon === 'climate' && (
                <svg class="w-7 h-7 text-indigo-600 group-hover:text-indigo-800 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8H5.5a2.5 2.5 0 000 5H8a2 2 0 012 2v1.055M20 21v-8a2 2 0 00-2-2h-1.055M16.5 12.5A2.5 2.5 0 0014 10h-4a2.5 2.5 0 000 5h4a2.5 2.5 0 001.5-2.5z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-3">{area.title}</h3>
            <p class="text-gray-600 mb-4 leading-relaxed">{area.description}</p>
            <a href="/what-we-do" class="text-indigo-600 font-semibold hover:text-indigo-800 inline-flex items-center">Learn more <span class="ml-1">→</span></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission Vision Section -->
  <section class="relative py-16 md:py-20 overflow-hidden">
    <div class="animated-bg absolute inset-0 z-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl shadow-sm p-8 border-l-4 border-indigo-600">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Our Mission</span>
          <p class="text-gray-700 mt-3 leading-relaxed">{mission}</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-8 border-l-4 border-indigo-600">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Our Vision</span>
          <p class="text-gray-700 mt-3 leading-relaxed">{vision}</p>
        </div>
        <div class="bg-indigo-50 rounded-xl shadow-sm p-8 border-l-4 border-green-600">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Our Values</span>
          <p class="text-gray-700 mt-3 leading-relaxed">{coreValues}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-indigo-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">Join Us in Making a Difference</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">Your support can help us continue our work in Isingiro District. Whether through donations, volunteering, or spreading the word, every contribution matters.</p>
      <a href="/get-involved" class="inline-block border-2 border-indigo-600 hover:bg-indigo-50 text-indigo-700 px-8 py-4 rounded-xl text-lg font-semibold transition-all duration-300">Get Involved Today <span class="ml-1">→</span></a>
    </div>
  </section>
</Layout>

<style>
  /* Animated Background */
  .animated-bg {
    background: linear-gradient(-45deg, #ffffff, #f9fafb, #eef2ff, #ffffff);
    background-size: 400% 400%;
    animation: gradientShift 15s ease infinite;
  }
  
  .animated-bg-alt {
    background: linear-gradient(-45deg, #f9fafb, #ffffff, #eef2ff, #f9fafb);
    background-size: 400% 400%;
    animation: gradientShift 15s ease infinite;
  }
  
  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>