---
import Layout from '../layouts/Layout.astro';

const mission = "To empower communities in Isingiro District by providing knowledge and sustainable development that enhances a quality life for the most vulnerable populations.";

const vision = "To build a thriving, healthy and well educated community where every individual has the opportunity to achieve their full potential.";

const workAreas = [
  {
    title: "Health",
    description: "Improving health outcomes through healthcare access, nutrition programs, and health education initiatives."
  },
  {
    title: "Education",
    description: "Expanding access to quality education by supporting schools, training teachers, and providing learning materials."
  },
  {
    title: "Climate Justice",
    description: "Promoting climate education and environmental stewardship while building community resilience."
  }
];
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative bg-primary text-white overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-20">
      <img src="/foundation.jpg" alt="Community" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 font-heading">Empowering Communities in Isingiro District</h1>
      <p class="text-lg md:text-xl max-w-2xl mx-auto mb-8 text-blue-100">Building a healthier, better-educated future for all.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/get-involved" class="bg-secondary hover:bg-secondary-dark text-white px-8 py-3 rounded-lg font-semibold transition shadow-md">Get Involved Today</a>
        <a href="/what-we-do" class="bg-transparent border border-white hover:bg-white hover:text-primary text-white px-8 py-3 rounded-lg font-semibold transition">Learn More</a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-3xl font-black text-primary font-heading">3</div>
          <div class="text-gray-600">Program Areas</div>
        </div>
        <div>
          <div class="text-3xl font-black text-primary font-heading">1000+</div>
          <div class="text-gray-600">Lives Impacted</div>
        </div>
        <div>
          <div class="text-3xl font-black text-primary font-heading">5+</div>
          <div class="text-gray-600">Years Serving</div>
        </div>
      </div>
    </div>
  </div>

  <!-- What We Do Cards -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4 font-heading">Our Mission in Action</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">We work across three key areas to create lasting positive change in Isingiro District.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {workAreas.map((area) => (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-lg transition duration-300">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mb-4">
            {area.title === 'Health' && (
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            )}
            {area.title === 'Education' && (
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            )}
            {area.title === 'Climate Justice' && (
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-2 font-heading">{area.title}</h3>
          <p class="text-gray-600 mb-4">{area.description}</p>
          <a href="/what-we-do" class="text-primary font-medium hover:text-primary-dark inline-flex items-center">Learn more <span class="ml-1">→</span></a>
        </div>
      ))}
    </div>
  </div>

  <!-- Mission & Vision Block -->
  <div class="bg-gray-50 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold text-primary mb-4 font-heading">Our Mission</h3>
          <p class="text-gray-700">{mission}</p>
        </div>
        <div>
          <h3 class="text-2xl font-bold text-primary mb-4 font-heading">Our Vision</h3>
          <p class="text-gray-700">{vision}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Donate Prompt -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4 font-heading">Join Us in Making a Difference</h2>
    <p class="text-lg text-gray-600 mb-8">Your support can help us continue our work in Isingiro District. Whether through donations, volunteering, or spreading the word, every contribution matters.</p>
    <a href="/get-involved" class="inline-block bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-xl text-lg font-semibold shadow-md transition">Get Involved Today <span class="ml-1">→</span></a>
  </div>
</Layout>