---
import Layout from '../layouts/Layout.astro';

const mission = "To empower communities in Isingiro District by providing knowledge and sustainable development that enhances a quality life for the most vulnerable populations.";

const vision = "To build a thriving, healthy and well educated community where every individual has the opportunity to achieve their full potential.";

const coreValues = "Giving a hand to another, Resilience, Innovation, Prosperity for future generations.";

const workAreas = [
  {
    title: "Health",
    description: "Improving health outcomes for vulnerable populations through healthcare access, nutrition programs, and health education initiatives.",
    icon: "health"
  },
  {
    title: "Education",
    description: "Expanding access to quality education by supporting schools, training teachers, and providing learning materials to students in need.",
    icon: "education"
  },
  {
    title: "Climate Justice",
    description: "Promoting climate education and environmental stewardship while building community resilience to climate change impacts.",
    icon: "climate"
  }
];
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1 class="animate-fade-in-up">Kato Laban Foundation</h1>
      <p class="tagline animate-fade-in-up" style="animation-delay: 0.1s">For Health and Education</p>
      <p class="hero-text animate-fade-in-up" style="animation-delay: 0.2s">Empowering communities in Isingiro District to build a healthier, better educated future for all.</p>
      <div class="hero-actions animate-fade-in-up" style="animation-delay: 0.3s">
        <a href="/get-involved" class="btn btn-primary">Get Involved</a>
        <a href="/what-we-do" class="btn btn-outline">Learn More</a>
      </div>
    </div>
  </section>

  <section class="section about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <span class="section-label">About Us</span>
          <h2>Building a Better Future for Isingiro District</h2>
          <p class="about-text">{mission}</p>
          <a href="/about" class="learn-more">Learn more about us <span class="arrow">→</span></a>
        </div>
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">3</span>
            <span class="stat-label">Program Areas</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">1000+</span>
            <span class="stat-label">Lives Impacted</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">5+</span>
            <span class="stat-label">Years Serving</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">1</span>
            <span class="stat-label">District Covered</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section work-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">What We Do</span>
        <h2>Our Mission in Action</h2>
        <p>We work across three key areas to create lasting positive change in Isingiro District.</p>
      </div>
      <div class="work-grid">
        {workAreas.map((area, index) => (
          <div class="work-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="work-icon">
              {area.icon === 'health' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              )}
              {area.icon === 'education' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              )}
              {area.icon === 'climate' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8H5.5a2.5 2.5 0 000 5H8a2 2 0 012 2v1.055M20 21v-8a2 2 0 00-2-2h-1.055M16.5 12.5A2.5 2.5 0 0014 10h-4a2.5 2.5 0 000 5h4a2.5 2.5 0 001.5-2.5z" />
                </svg>
              )}
            </div>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
            <a href="/what-we-do" class="card-link">Learn more <span class="arrow">→</span></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section vision-section">
    <div class="container">
      <div class="vision-grid">
        <div class="vision-card">
          <span class="card-label">Our Mission</span>
          <h3>{mission}</h3>
        </div>
        <div class="vision-card">
          <span class="card-label">Our Vision</span>
          <h3>{vision}</h3>
        </div>
        <div class="vision-card accent">
          <span class="card-label">Our Values</span>
          <h3>{coreValues}</h3>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-card">
        <div class="cta-content">
          <h2>Join Us in Making a Difference</h2>
          <p>Your support can help us continue our work in Isingiro District. Whether through donations, volunteering, or spreading the word, every contribution matters.</p>
          <a href="/get-involved" class="btn btn-primary">Get Involved Today</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    background-image: url('/foundation.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(30, 58, 138, 0.92) 0%, rgba(59, 139, 94, 0.85) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-4xl) 0;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero h1 {
    color: var(--color-white);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .tagline {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .hero-text {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--spacing-2xl);
    line-height: 1.7;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-md) var(--spacing-xl);
    font-weight: 600;
    font-size: 1rem;
    text-align: center;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--color-neutral-900);
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(245, 158, 11, 0.3);
  }

  .btn-outline {
    background-color: transparent;
    color: var(--color-white);
    border: 2px solid var(--color-white);
  }

  .btn-outline:hover {
    background-color: var(--color-white);
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  .section {
    padding: var(--spacing-4xl) 0;
  }

  .section-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--spacing-sm);
  }

  .about-section {
    background-color: var(--color-white);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
    align-items: center;
  }

  .about-content h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
    line-height: 1.2;
  }

  .about-text {
    font-size: 1.125rem;
    color: var(--color-neutral-600);
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
  }

  .learn-more {
    font-weight: 600;
    color: var(--color-secondary);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .learn-more .arrow {
    transition: transform 0.3s ease;
  }

  .learn-more:hover .arrow {
    transform: translateX(5px);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .stat-card {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    padding: var(--spacing-xl);
    border-radius: var(--border-radius-xl);
    text-align: center;
    color: var(--color-white);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.875rem;
    opacity: 0.9;
  }

  .work-section {
    background-color: var(--color-neutral-50);
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--spacing-3xl);
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .section-header p {
    font-size: 1.125rem;
    color: var(--color-neutral-500);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
  }

  .work-card {
    background-color: var(--color-white);
    padding: var(--spacing-2xl);
    border-radius: var(--border-radius-xl);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border: 1px solid var(--color-neutral-100);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .work-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .work-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(30, 58, 138, 0.12);
  }

  .work-card:hover::before {
    transform: scaleX(1);
  }

  .work-icon {
    width: 70px;
    height: 70px;
    margin-bottom: var(--spacing-lg);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    border-radius: var(--border-radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .work-icon svg {
    width: 36px;
    height: 36px;
    color: var(--color-white);
  }

  .work-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  .work-card p {
    color: var(--color-neutral-600);
    line-height: 1.7;
    margin-bottom: var(--spacing-lg);
  }

  .card-link {
    font-weight: 600;
    color: var(--color-secondary);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-link .arrow {
    transition: transform 0.3s ease;
  }

  .card-link:hover .arrow {
    transform: translateX(5px);
  }

  .vision-section {
    background-color: var(--color-white);
  }

  .vision-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .vision-card {
    background-color: var(--color-neutral-50);
    padding: var(--spacing-xl);
    border-radius: var(--border-radius-xl);
    border-left: 4px solid var(--color-primary);
  }

  .vision-card.accent {
    border-left-color: var(--color-secondary);
    background: linear-gradient(135deg, var(--color-neutral-50) 0%, #f0fdf4 100%);
  }

  .vision-card .card-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-neutral-400);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .vision-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-neutral-700);
    line-height: 1.6;
  }

  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    padding: var(--spacing-4xl) 0;
  }

  .cta-card {
    text-align: center;
  }

  .cta-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-content h2 {
    color: var(--color-white);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-bottom: var(--spacing-md);
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    margin-bottom: var(--spacing-xl);
    line-height: 1.7;
  }

  @media (max-width: 968px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-2xl);
    }

    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .work-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }

    .vision-grid {
      grid-template-columns: 1fr;
      max-width: 600px;
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 70vh;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat-number {
      font-size: 2rem;
    }
  }
</style>