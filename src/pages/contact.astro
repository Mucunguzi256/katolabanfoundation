---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <!-- Hero -->
  <section class="hero-half">
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <nav class="breadcrumb">Home &gt; Contact</nav>
      <h1>Contact Us</h1>
      <p>We would love to hear from you. Get in touch with any questions or inquiries.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Get In Touch</h2>
          <p>Have questions about our work or want to partner with us? We are here to help. Reach out through any of the channels below.</p>
          
          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon">📞</div>
              <div>
                <h3>Phone</h3>
                <p><a href="tel:+256784332800">+256 784 332 800</a></p>
              </div>
            </div>
            
            <div class="contact-item">
              <div class="contact-icon">✉️</div>
              <div>
                <h3>Email</h3>
                <p><a href="mailto:contact@katolabanfoundation.org">contact@katolabanfoundation.org</a></p>
              </div>
            </div>
            
            <div class="contact-item">
              <div class="contact-icon">📍</div>
              <div>
                <h3>Address</h3>
                <p>Kato Laban Foundation<br />Kikagate Town Council<br />Isingiro District<br />Uganda</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="contact-form-card">
          <h2>Send Us a Message</h2>
          <p>Fill out the form below and we will get back to you within 48 hours.</p>
          
          <form class="contact-form" name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />
            
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required />
            </div>
            
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" required />
            </div>
            
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="map-section">
    <div class="container">
      <h2>Find Us</h2>
      <iframe
        class="map-embed"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.4!2d30.8!3d-0.85!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sKikagate%2C+Isingiro+District%2C+Uganda!5e0!3m2!1sen!2sug!4v1"
        width="100%"
        height="400"
        style="border:0; border-radius: 1rem;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Kato Laban Foundation Location - Kikagate Town Council, Isingiro District"
      ></iframe>
    </div>
  </section>
</Layout>

<style>
  .hero-half {
    position: relative;
    min-height: 60vh;
    background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(233, 162, 59, 0.15) 0%, transparent 50%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
    padding: 0 2rem;
  }

  .breadcrumb {
    font-size: 0.9rem;
    color: #E9A23B;
    margin-bottom: 1.5rem;
  }

  .hero-half h1 {
    color: #FFFFFF;
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .hero-half p {
    color: #D1D5DB;
    font-size: 1.25rem;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Contact Section */
  .contact-section {
    background-color: #F9F7F4;
    padding: 6rem 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
  }

  .contact-info h2,
  .contact-form-card h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .contact-info > p {
    color: #6B7280;
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-icon {
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #2D6A4F 0%, #E9A23B 100%);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-item h3 {
    font-size: 1rem;
    color: #111827;
    margin-bottom: 0.25rem;
  }

  .contact-item p {
    color: #6B7280;
    margin: 0;
  }

  .contact-item a {
    color: #2D6A4F;
    font-weight: 500;
  }

  .contact-form-card {
    background-color: #FFFFFF;
    padding: 2.5rem;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .contact-form-card > p {
    color: #6B7280;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #D1D5DB;
    border-radius: 0.5rem;
    background-color: #F9F7F4;
    font-size: 1rem;
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #2D6A4F;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn {
    width: 100%;
    padding: 0.875rem 2rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background-color: #2D6A4F;
    color: #FFFFFF;
  }

  .btn-primary:hover {
    background-color: #1B4332;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(45, 106, 79, 0.3);
  }

  /* Map */
  .map-section {
    background-color: #FFFFFF;
    padding: 6rem 0;
  }

  .map-section h2 {
    text-align: center;
    margin-bottom: 2rem;
  }

  .map-embed {
    width: 100%;
    height: 400px;
    border: none;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  @media (max-width: 768px) {
    .hero-half { min-height: 50vh; }
    .hero-half h1 { font-size: 2.25rem; }
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    .contact-details { flex-direction: column; }
  }
</style>