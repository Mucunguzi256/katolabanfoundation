---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Involved">
  <section class="page-header">
    <div class="container">
      <h1>Get Involved</h1>
      <p>Join us in making a difference in Isingiro District. Your support matters.</p>
    </div>
  </section>

  <section class="section donate-section">
    <div class="container">
      <div class="action-grid">
        <div class="action-card">
          <h2>Donate</h2>
          <p>Your financial support helps us continue our programs in health, education, and climate justice. Every contribution, no matter the size, makes a real difference in the lives of those we serve.</p>
          <p>We ensure that donations are used efficiently and effectively to maximize impact in Isingiro District.</p>
          <button class="btn btn-accent">Donate Now</button>
        </div>
        <div class="action-card">
          <h2>Volunteer</h2>
          <p>Your time and skills are valuable. We welcome volunteers who want to make a difference, whether locally in Isingiro District or remotely supporting our programs.</p>
          <p>Volunteer opportunities include teaching, healthcare support, administrative work, and more.</p>
          <a href="#volunteer-form" class="btn btn-secondary">Sign Up to Volunteer</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section volunteer-form-section" id="volunteer-form">
    <div class="container">
      <div class="form-content">
        <h2>Volunteer With Us</h2>
        <p>Fill out the form below to express your interest in volunteering. We will get back to you within one week.</p>
        
        <form class="volunteer-form" action="https://formspree.io/f/contact@katolabanfoundation.org" method="POST">
          <input type="hidden" name="_subject" value="New Volunteer Sign Up" />
          
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" required />
          </div>
          
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required />
          </div>
          
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" />
          </div>
          
          <div class="form-group">
            <label for="interest">Area of Interest</label>
            <select id="interest" name="interest">
              <option value="">Select an option</option>
              <option value="teaching">Teaching</option>
              <option value="healthcare">Healthcare</option>
              <option value="administration">Administration</option>
              <option value="outreach">Community Outreach</option>
              <option value="fundraising">Fundraising</option>
              <option value="other">Other</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about yourself and why you want to volunteer..."></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary">Submit</button>
        </form>
      </div>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-card">
          <h3>Phone</h3>
          <p><a href="tel:+256784332800">+256 784 332 800</a></p>
        </div>
        <div class="contact-card">
          <h3>Email</h3>
          <p><a href="mailto:contact@katolabanfoundation.org">contact@katolabanfoundation.org</a></p>
        </div>
        <div class="contact-card">
          <h3>Address</h3>
          <p>Kikagate Town Council<br />Isingiro District<br />Uganda</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    padding: var(--spacing-3xl) 0;
    text-align: center;
    position: relative;
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/foundation.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.3;
  }

  .page-header > * {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
  }

  .page-header p {
    color: var(--color-neutral-100);
    font-size: var(--font-size-lg);
    max-width: 600px;
    margin: 0 auto;
  }

  .donate-section {
    background-color: var(--color-neutral-50);
  }

  .action-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-xl);
  }

  .action-card {
    background-color: var(--color-white);
    padding: var(--spacing-2xl);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .action-card h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .action-card p {
    color: var(--color-neutral-600);
    line-height: 1.7;
    margin-bottom: var(--spacing-lg);
  }

  .volunteer-form-section {
    background-color: var(--color-white);
  }

  .form-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .form-content h2 {
    text-align: center;
    margin-bottom: var(--spacing-md);
  }

  .form-content > p {
    text-align: center;
    color: var(--color-neutral-600);
    margin-bottom: var(--spacing-xl);
  }

  .volunteer-form {
    background-color: var(--color-neutral-50);
    padding: var(--spacing-xl);
    border-radius: var(--border-radius-lg);
  }

  .form-group {
    margin-bottom: var(--spacing-lg);
  }

  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: var(--spacing-xs);
    color: var(--color-neutral-700);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid var(--color-neutral-300);
    border-radius: var(--border-radius-md);
    background-color: var(--color-white);
    transition: border-color var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .volunteer-form .btn {
    width: 100%;
  }

  .contact-section {
    background-color: var(--color-neutral-100);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
  }

  .contact-card {
    text-align: center;
  }

  .contact-card h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  .contact-card p {
    color: var(--color-neutral-600);
    margin: 0;
  }

  .contact-card a {
    color: var(--color-primary);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--spacing-2xl) 0;
    }

    .action-grid {
      grid-template-columns: 1fr;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>